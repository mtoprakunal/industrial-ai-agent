# ============================================================
# OPC-UA -> WebSocket Gateway konfigürasyonu
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.
# ============================================================

# --- OPC-UA (PLC) bağlantısı ---
# CODESYS SoftPLC örneği: opc.tcp://<plc-ip>:4840
OPCUA_ENDPOINT=opc.tcp://192.168.1.100:4840

# CODESYS namespace URI — namespace index BUNDAN dinamik alınır (hardcode etme!)
OPCUA_NAMESPACE_URI=http://www.3s-software.com/schemas/Codesys-V3

# OPC-UA kullanıcı kimliği (anonim için boş bırakın)
OPCUA_USER=
OPCUA_PASS=

# Güvenlik: None | Sign | SignAndEncrypt  /  None | Basic256Sha256
# Geliştirmede None, üretimde SignAndEncrypt + Basic256Sha256 önerilir.
OPCUA_SECURITY_MODE=None
OPCUA_SECURITY_POLICY=None

# --- WebSocket sunucusu (tarayıcı tarafı) ---
WS_PORT=8080

# Yazma komutları için basit paylaşılan sır (üretimde gerçek JWT/oturum ile değiştirin)
# Boş bırakılırsa yazma kimlik doğrulaması DEVRE DIŞI (yalnız geliştirme!).
WRITE_AUTH_TOKEN=

# --- Davranış ---
# WebSocket'e gönderilen batch penceresi (ms). Yüksek frekanslı tag'leri birleştirir.
BATCH_INTERVAL_MS=100
