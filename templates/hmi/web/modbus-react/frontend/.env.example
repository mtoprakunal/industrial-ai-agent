# Frontend yapilandirmasi (Vite — degiskenler VITE_ ile baslamali).
#   cp .env.example .env

# Gateway WebSocket adresi. Bos birakilirsa sayfanin hostname'i + :8080 kullanilir.
# Uretimde wss:// (TLS) kullanin.
VITE_WS_URL=ws://localhost:8080

# Yazma yetki token'i (gateway .env'deki WRITE_TOKEN ile ayni olmali).
VITE_WRITE_TOKEN=
