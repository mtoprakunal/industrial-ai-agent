# ============================================================================
#  Modbus -> WebSocket Gateway Yapilandirmasi
#  Kullanim: bu dosyayi `.env` olarak kopyalayip kendi degerlerinizi girin.
#    cp .env.example .env
# ============================================================================

# --- Modbus TCP slave (PLC) baglanti bilgileri ---
MODBUS_HOST=192.168.1.100   # PLC / Modbus slave IP adresi
MODBUS_PORT=502             # Modbus TCP standart portu
MODBUS_UNIT_ID=1            # Slave / Unit ID (gateway arkasi RTU icin onemli)

# --- Polling ve zamanlamalar (ms) ---
POLL_INTERVAL_MS=500        # PLC okuma periyodu (PLC CPU yukune gore ayarla)
MODBUS_TIMEOUT_MS=2000      # Tek istek timeout'u (cevapsiz istek tum donguyu kilitlemesin)
RECONNECT_MS=5000           # Baglanti kopunca yeniden deneme araligi

# --- WebSocket sunucu ---
WS_PORT=8080                # React frontend bu porta baglanir

# --- Yazma yetkisi (Modbus'ta auth yok; basit guard) ---
# Bos birakilirsa yazma serbest (sadece izole/test agi icin!).
# Bir token girilirse frontend WRITE mesajlarinda ayni token'i gondermek zorunda.
WRITE_TOKEN=
