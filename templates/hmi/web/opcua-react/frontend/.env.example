# Gateway WebSocket adresi.
# Boş bırakılırsa frontend, sayfanın host'una :8080 ile bağlanır
# (ws://<window.location.hostname>:8080).
VITE_WS_URL=ws://localhost:8080

# Yazma komutları için paylaşılan token (gateway WRITE_AUTH_TOKEN ile aynı olmalı).
# Boşsa yazma doğrulaması kapalıdır (yalnız geliştirme).
VITE_WRITE_AUTH_TOKEN=
