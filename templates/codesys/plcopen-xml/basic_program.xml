    <types>
        <dataTypes/>
        <pous>
            <pou name="PLC_PRG" pouType="program">
                <interface>
                    <localVars>
                        <variable name="xRun">
                            <type><BOOL/></type>
                            <documentation>
                                <xhtml xmlns="http://www.w3.org/1999/xhtml">Program calisma bayragi</xhtml>
                            </documentation>
                        </variable>
                        <variable name="iCounter">
                            <type><INT/></type>
                            <initialValue>
                                <simpleValue value="0"/>
                            </initialValue>
                        </variable>
                        <variable name="rValue">
                            <type><REAL/></type>
                            <initialValue>
                                <simpleValue value="0.0"/>
                            </initialValue>
                        </variable>
                    </localVars>
                </interface>
                <body>
                    <ST>
                        <xhtml xmlns="http://www.w3.org/1999/xhtml"><![CDATA[
// ------------------------------------------------------------
// PLC_PRG - Temel program sablonu
// Her cevrimde sayaci artirir ve basit bir hesaplama yapar.
// ------------------------------------------------------------

xRun := TRUE;

IF xRun THEN
    iCounter := iCounter + 1;

    // 1000'e ulasinca basa don
    IF iCounter >= 1000 THEN
        iCounter := 0;
    END_IF

    // Ornek hesaplama
    rValue := INT_TO_REAL(iCounter) * 0.1;
END_IF
]]></xhtml>
                    </ST>
                </body>
            </pou>
        </pous>
