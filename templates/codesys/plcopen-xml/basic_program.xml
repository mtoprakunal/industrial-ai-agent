    <contentHeader name="BasicProgramTemplate"
                   modificationDateTime="2026-06-10T10:00:00">
        <coordinateInfo>
            <fbd><scaling x="1" y="1"/></fbd>
            <ld><scaling x="1" y="1"/></ld>
            <sfc><scaling x="1" y="1"/></sfc>
        </coordinateInfo>
